{
  "name": "notion-to-ppt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "convert": "bun run src/index.ts",
    "convert-docx": "bun run src/docx.ts",
    "install:browsers": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "commander": "^14.0.0",
    "docx": "^9.6.1",
    "image-size": "^2.0.2",
    "mermaid": "^11.14.0",
    "playwright": "^1.59.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}